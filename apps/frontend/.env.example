# Environment Variables for Deexen Frontend

# FastAPI backend (apps/backend)
VITE_API_URL=http://localhost:8000

# Workspace backend (apps/backend-node)
VITE_WORKSPACE_API_URL=http://localhost:3000

# Socket.IO host (defaults to VITE_WORKSPACE_API_URL if not set)
VITE_WS_URL=http://localhost:3000

# Supabase (optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Keep disabled for production
VITE_USE_MOCK=false
